{
  "name": "@adminforth/foreign-inline-list",
  "version": "1.0.27",
  "description": "AdminForth plugin for adding list of children items to the parent item show page",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://adminforth.dev/docs/tutorial/Plugins/foreign-inline-list/",
  "scripts": {
    "build": "tsc && rsync -av --exclude 'node_modules' custom dist/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/devforth/adminforth-foreign-inline-list.git"
  },
  "author": "DevForth (https://devforth.io)",
  "keywords": [
    "adminforth",
    "list foreign items"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.7",
    "adminforth": "^3.7.1",
    "semantic-release": "^24.2.1",
    "semantic-release-slack-bot": "^4.0.2",
    "typescript": "^5.7.3"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "semantic-release-slack-bot",
        {
          "packageName": "@adminforth/foreign-inline-list",
          "notifyOnSuccess": true,
          "notifyOnFail": true,
          "slackIcon": ":package:",
          "markdownReleaseNotes": true
        }
      ]
    ],
    "branches": [
      "main",
      {
        "name": "next",
        "prerelease": true
      }
    ]
  },
  "dependencies": {
    "clone": "^2.1.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "adminforth": "^3.7.1"
  }
}
